{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/Badge/**",
              "components/Button/**",
              "components/CodeBlock/**",
              "components/DiagnosticCard/**",
              "components/SignalIndicator/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Hanken Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Hanken Grotesk, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|dot|solid|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, dot, solid."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|mono|leadingIcon|trailingIcon|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, mono, leadingIcon, trailingIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='CodeBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:code|children|filename|language|showLineNumbers|highlight|showChrome|copyable|key|ref|className|style|children)$/]",
        "message": "<CodeBlock> doesn't accept that prop. Declared props: code, children, filename, language, showLineNumbers, highlight, showChrome, copyable."
      },
      {
        "selector": "JSXOpeningElement[name.name='DiagnosticCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:severity|id|title|location|confidence|signals|fix|fixLabel|actions|key|ref|className|style|children)$/]",
        "message": "<DiagnosticCard> doesn't accept that prop. Declared props: severity, id, title, location, confidence, signals, fix, fixLabel, actions."
      },
      {
        "selector": "JSXOpeningElement[name.name='SignalIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|value|confidence|status|state|key|ref|className|style|children)$/]",
        "message": "<SignalIndicator> doesn't accept that prop. Declared props: name, value, confidence, status, state."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Badge": {
        "replaces": []
