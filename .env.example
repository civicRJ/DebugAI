# Copy to ".env" and fill in your values. ".env" is gitignored — never committed.
# ./run.sh loads it automatically.

# ── Required for production ──────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-to-a-strong-random-password
DEBUGAI_DOMAIN=yourdomain.com       # auto-provisions TLS via Caddy + Let's Encrypt
DEBUGAI_TRUST_PROXY=1               # always set when behind Caddy/nginx

# ── LLM features (optional — works without them) ─────────────────────────────
OPENAI_API_KEY=sk-...               # instruction-adherence judge + Socratic fix rerun
DEBUGAI_JUDGE_MODEL=gpt-5.5        # override if this model id is not valid for your key
ANTHROPIC_API_KEY=sk-ant-...       # live Layer-3 explainer + grounding fix rerun

# ── Additional hardening (optional) ─────────────────────────────────────────
# DEBUGAI_API_KEY=                  # require X-API-Key on /api/* at the network edge
# DEBUGAI_RATE_LIMIT=240            # /api/* requests per minute per client (default 240)
# DEBUGAI_AUTH_RATE_LIMIT=30        # /api/auth/login|register per minute (default 30; set 0 to disable)

# ── Local dev overrides ──────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434/v1  # if Ollama is on a non-default port
